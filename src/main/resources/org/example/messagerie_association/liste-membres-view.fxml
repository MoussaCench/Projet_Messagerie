<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.messagerie_association.ListeMembresController"
            prefHeight="480.0" prefWidth="720.0" styleClass="root">
    <children>
        <Text layoutX="20" layoutY="32" styleClass="titre-section" text="Liste complète des membres inscrits (RG13)" />
        <TableView fx:id="tab_membres" layoutX="20" layoutY="50" prefHeight="380" prefWidth="680" styleClass="table-view">
            <columns>
                <TableColumn fx:id="col_id" prefWidth="50" text="ID" />
                <TableColumn fx:id="col_username" prefWidth="120" text="Username" />
                <TableColumn fx:id="col_nom" prefWidth="150" text="Nom" />
                <TableColumn fx:id="col_email" prefWidth="180" text="Email" />
                <TableColumn fx:id="col_role" prefWidth="100" text="Rôle" />
                <TableColumn fx:id="col_status" prefWidth="80" text="Statut" />
                <TableColumn fx:id="col_date" prefWidth="120" text="Date création" />
            </columns>
        </TableView>
        <Button layoutX="620" layoutY="440" text="Fermer" onAction="#fermer" styleClass="bouton-secondaire" prefWidth="80" prefHeight="32" />
    </children>
</AnchorPane>
